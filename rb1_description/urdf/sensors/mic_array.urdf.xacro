<?xml version="1.0" ?>
<robot name="mic_array" xmlns:xacro="http://ros.org/wiki/xacro">
    <xacro:macro name="mic_array" params="name parent">
        <joint name="${name}_joint" type="fixed">
            <origin xyz="0.0 0.02 0.07" rpy="0.0 0.0 0.0"/>
            <parent link="${parent}"/>
            <child link="${name}_link"/>
        </joint>
        <link name="${name}_link">
            <inertial>
                <origin xyz="0.06 0.13 0.0" rpy="0.0 0.0 0.0"/>
                <mass value="0.04"/>
                <inertia ixx="0.00000429247" ixy="0.00000000000" ixz="0.00000002565" iyy="0.00000008027" iyz="0.00000000000" izz="0.00000427339"/>
            </inertial>
            <visual>
                <geometry>
                    <cylinder radius="0.05" length="0.002"/>  <!-- Ajusta el radio y grosor -->
                </geometry>
                <material name="navy_blue">
                    <color rgba="0.0 0.0 0.5 1.0"/>
                </material>
            </visual>
        </link>
        <link name="mic_1">
            <visual>
            <geometry>
                <box size="0.01 0.01 0.002"/>
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
            </visual>
        </link>
        <joint name="mic_1_joint" type="fixed">
            <parent link="${name}_link"/>
            <child link="mic_1"/>
            <origin rpy="0 0 2.36" xyz="-0.0405 0.0000 0.001"/>
        </joint>
